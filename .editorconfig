dotnet_diagnostic.SA1648.severity = none
dotnet_diagnostic.SA1649.severity = none
dotnet_diagnostic.SA1651.severity = none

#### Meziantou — Suppressions ####

# MA0004: Use ConfigureAwait(false) — not needed in ASP.NET Core
dotnet_diagnostic.MA0004.severity = none

# MA0026: Fix TODO comment — advisory only
dotnet_diagnostic.MA0026.severity = suggestion

# MA0048: File name must match type name — conflicts with grouped types
dotnet_diagnostic.MA0048.severity = none

# MA0049: Type should be marked as sealed — enforce incrementally
dotnet_diagnostic.MA0049.severity = suggestion

# MA0051: Method is too long — advisory only
dotnet_diagnostic.MA0051.severity = suggestion

#### Test project overrides ####
[tests/**/*.cs]

# CA1707: Identifiers should not contain underscores — standard test naming convention
dotnet_diagnostic.CA1707.severity = none
