@page "/search"
@rendermode InteractiveServer

<PageTitle>Search</PageTitle>

<div class="mox-container-narrow" style="padding-top: 28px; padding-bottom: 64px;">
    <!-- Search bar -->
    <div class="search-bar">
        <i class="bi bi-search" style="color: var(--mox-muted-light); font-size: 16px; flex-shrink: 0;"></i>
        <input type="text"
               class="search-input"
               placeholder="Search tweets, users, tags..."
               @bind="_query"
               @onkeydown="HandleSearchKeyDown" />
        <button class="mox-btn-primary" style="flex-shrink: 0; padding: 8px 22px; font-size: 14px;" @onclick="ExecuteSearch">
            Search
        </button>
    </div>

    <!-- Filters -->
    <div class="filter-row">
        <select class="mox-input" style="width: auto; padding: 8px 12px; font-size: 13px;">
            <option>All tags</option>
        </select>
        <input type="text"
               class="mox-input"
               placeholder="@@username"
               style="width: 140px; padding: 8px 12px; font-size: 13px;"
               @bind="_username" />
        <select class="mox-input" style="width: auto; padding: 8px 12px; font-size: 13px;" @bind="_sort">
            <option value="votes">Most Voted</option>
            <option value="newest">Newest</option>
        </select>
        <div class="view-toggle">
            <button class="toggle-btn @(!_compactMode ? "active" : "")" @onclick="@(() => _compactMode = false)" title="Compact — faster scanning">
                <i class="bi bi-list"></i> Compact
            </button>
            <button class="toggle-btn @(_compactMode ? "active" : "")" @onclick="@(() => _compactMode = true)" title="Comfortable — full metadata">
                <i class="bi bi-card-text"></i> Comfortable
            </button>
        </div>
    </div>

    @if (_loading)
    {
        <LoadingSkeleton Count="4" />
    }
    else if (_model is not null)
    {
        @if (!string.IsNullOrEmpty(_model.Query))
        {
            <p style="font-size: 14px; color: var(--mox-muted); margin-bottom: 18px;">
                <strong style="color: var(--mox-ink);">@_model.TotalCount results</strong> for "@_model.Query"
            </p>
        }

        @if (_model.SubjectProfile is not null)
        {
            <div class="subject-profile-card">
                <div class="subject-avatar">
                    @GetInitial(_model.SubjectProfile.XUsername)
                </div>
                <div style="flex: 1;">
                    <div style="font-weight: 700; font-size: 15px;">
                        @@@_model.SubjectProfile.XUsername
                        @if (!string.IsNullOrEmpty(_model.SubjectProfile.DisplayName))
                        {
                            <span style="color: var(--mox-muted); font-weight: 400; font-size: 13.5px;"> &middot; @_model.SubjectProfile.DisplayName</span>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(_model.SubjectProfile.Description))
                    {
                        <p style="font-size: 13.5px; color: var(--mox-muted); margin: 3px 0 0; line-height: 1.45;">
                            @_model.SubjectProfile.Description
                        </p>
                    }
                </div>
                <a href="/u/@_model.SubjectProfile.XUserId" style="font-size: 13px; color: var(--mox-accent); font-weight: 600; text-decoration: none; flex-shrink: 0;">
                    View profile →
                </a>
            </div>
        }

        @if (_model.FolderResults is not null && _model.FolderResults.Count > 0)
        {
            <div class="search-section-label">Folders</div>
            <div class="search-folders-grid">
                @foreach (var folder in _model.FolderResults)
                {
                    <a href="/browse/@folder.Id" class="search-folder-card">
                        <div class="search-folder-icon">
                            <i class="bi @folder.Icon"></i>
                        </div>
                        <div style="flex: 1; min-width: 0;">
                            <div style="font-size: 15px; font-weight: 700;">@folder.Name</div>
                            @if (!string.IsNullOrEmpty(folder.OwnerUsername))
                            {
                                <div style="display: flex; align-items: center; gap: 6px; margin-top: 4px;">
                                    <span class="search-folder-owner-avatar">@folder.OwnerInitial</span>
                                    <span style="font-size: 12px; color: #8a7f6e;">by <span style="color: var(--mox-accent); font-weight: 600;">@@@folder.OwnerUsername</span></span>
                                </div>
                            }
                            <div style="font-size: 12px; color: var(--mox-muted-light); margin-top: 6px;">
                                @folder.TweetCount tweets &middot; @folder.SubfolderCount subfolders
                            </div>
                        </div>
                    </a>
                }
            </div>
        }

        @if (_model.Results.Count > 0)
        {
            @if (_model.FolderResults is not null && _model.FolderResults.Count > 0)
            {
                <div class="search-section-label">Tweets</div>
            }

            @foreach (var tweet in _model.Results)
            {
                <div style="margin-bottom: 14px;">
                    <TweetCard Tweet="@tweet"
                               ShowScreenshot="true"
                               ShowCapture="true"
                               ShowFolders="true"
                               CompactMode="@_compactMode"
                               OnVote="@(() => HandleVote(tweet.Id))" />
                </div>
            }

            <Pagination CurrentPage="@_model.CurrentPage"
                        TotalPages="@_model.TotalPages"
                        OnPageChange="@HandlePageChange" />
        }
        else if (!string.IsNullOrEmpty(_model.Query) || !string.IsNullOrEmpty(_model.Tag) || !string.IsNullOrEmpty(_model.Username))
        {
            <EmptyState Icon="bi-search"
                        Title="No tweets match your search"
                        Description="Try different keywords, or loosen the tag and author filters above." />
        }
    }
</div>

@code {
    private SearchPageModel? _model;
    private bool _loading;
    private string _query = "";
    private string _tag = "";
    private string _username = "";
    private string _sort = "votes";
    private bool _compactMode;
    private int _page = 1;
    private const int PageSize = 20;

    [Inject]
    private SearchOrchestrator Orchestrator { get; set; } = default!;

    [Inject]
    private NavigationManager Navigation { get; set; } = default!;

    [SupplyParameterFromQuery(Name = "q")]
    public string? InitialQuery { get; set; }

    [SupplyParameterFromQuery(Name = "tag")]
    public string? InitialTag { get; set; }

    [SupplyParameterFromQuery(Name = "username")]
    public string? InitialUsername { get; set; }

    protected override async Task OnInitializedAsync()
    {
        _query = InitialQuery ?? "";
        _tag = InitialTag ?? "";
        _username = InitialUsername ?? "";

        if (!string.IsNullOrEmpty(_query) || !string.IsNullOrEmpty(_tag) || !string.IsNullOrEmpty(_username))
        {
            await LoadData();
        }
    }

    private async Task LoadData()
    {
        _loading = true;
        StateHasChanged();

        _model = await Orchestrator.GetAsync(
            string.IsNullOrWhiteSpace(_query) ? null : _query,
            string.IsNullOrWhiteSpace(_tag) ? null : _tag,
            string.IsNullOrWhiteSpace(_username) ? null : _username,
            _sort,
            _page,
            PageSize);

        _loading = false;
    }

    private async Task ExecuteSearch()
    {
        _page = 1;
        await LoadData();
    }

    private async Task HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await ExecuteSearch();
        }
    }

    private async Task HandlePageChange(int page)
    {
        _page = page;
        await LoadData();
    }

    private async Task HandleVote(Guid tweetId)
    {
        await Task.CompletedTask;
    }

    private static string GetInitial(string name)
    {
        return string.IsNullOrEmpty(name) ? "?" : name[..1].ToUpperInvariant();
    }
}
