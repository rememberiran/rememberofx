@page "/browse"
@rendermode InteractiveServer

<PageTitle>Browse Folders</PageTitle>

@if (_loading)
{
    <div class="mox-container" style="padding-top: 32px;">
        <LoadingSkeleton Count="6" />
    </div>
}
else if (_model is not null)
{
    <div class="mox-container" style="padding-top: 32px;">
        <Breadcrumbs Items="@_breadcrumb" />

        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 28px;">
            <h1 style="font-family: var(--mox-font-serif); font-size: 30px; font-weight: 800; color: var(--mox-ink); margin: 0;">
                All Folders
            </h1>
            <button class="mox-btn-secondary" style="display: inline-flex; align-items: center; gap: 6px;">
                <i class="bi bi-plus-lg"></i> New Folder
            </button>
        </div>

        <div class="mox-grid-3">
            @foreach (var folder in _model.Folders)
            {
                <FolderCard Folder="@folder" />
            }
        </div>

        @if (_model.Folders.Count == 0)
        {
            <EmptyState Icon="bi-folder2-open"
                        Title="No folders yet"
                        Description="Create a folder to start organizing archived tweets." />
        }
    </div>
}

@code {
    private BrowsePageModel? _model;
    private bool _loading = true;

    private readonly List<BreadcrumbItemViewModel> _breadcrumb = new()
    {
        new("Home", "/"),
        new("Folders", null),
    };

    [Inject]
    private BrowseOrchestrator Orchestrator { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        _model = await Orchestrator.GetAsync();
        _loading = false;
    }
}
