@page "/browse/{FolderId:guid}"
@rendermode InteractiveServer

@if (_model is not null)
{
    <PageTitle>@_model.Folder.Name</PageTitle>
}
else
{
    <PageTitle>Folder</PageTitle>
}

@if (_loading)
{
    <div class="mox-container" style="padding-top: 32px;">
        <LoadingSkeleton Count="6" />
    </div>
}
else if (_model is not null)
{
    <div class="mox-container" style="padding-top: 32px; padding-bottom: 64px;">
        <Breadcrumbs Items="@_model.Breadcrumb.ToList()" />

        <div class="folder-header">
            <div>
                <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 8px; flex-wrap: wrap;">
                    <h1 style="font-family: var(--mox-font-serif); font-size: 30px; font-weight: 800; color: var(--mox-ink); margin: 0;">
                        @_model.Folder.Name
                    </h1>
                    <span class="detail-badge">
                        <i class="bi @(_model.Folder.Visibility == "public" ? "bi-globe2" : "bi-lock-fill")" style="font-size: 11px;"></i>
                        @(_model.Folder.Visibility == "public" ? "Public" : "Private")
                    </span>
                    <span class="detail-badge" style="border: 1px solid var(--mox-border-card); background: transparent;">
                        <i class="bi bi-diagram-3" style="font-size: 11px;"></i>
                        Level @_model.Depth of @_model.MaxDepth
                    </span>
                </div>
                @if (!string.IsNullOrEmpty(_model.Folder.Description))
                {
                    <p style="color: var(--mox-muted); font-size: 15px; line-height: 1.55; margin: 0; max-width: 680px;">
                        @_model.Folder.Description
                    </p>
                }
            </div>
            <button class="manage-pencil-btn" @onclick="OpenManagePanel" title="Manage folder">
                <i class="bi bi-pencil"></i>
            </button>
        </div>

        <!-- Subfolders section -->
        <div class="subfolders-section">
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px;">
                <span class="section-label">Subfolders</span>
                <button class="manage-link" @onclick="OpenManagePanel">
                    <i class="bi bi-sliders2"></i> Manage
                </button>
            </div>
            @if (_model.Subfolders.Count > 0)
            {
                <div class="subfolders-row">
                    @foreach (var sub in _model.Subfolders)
                    {
                        <a href="/browse/@sub.Id" class="subfolder-card">
                            <div style="display: flex; align-items: center; gap: 8px; font-weight: 600; font-size: 14px;">
                                <i class="bi bi-folder" style="color: var(--mox-accent);"></i>
                                @sub.Name
                                <i class="bi @(sub.Visibility == "public" ? "bi-globe2" : "bi-lock-fill")" style="color: var(--mox-faint); font-size: 11px; margin-left: auto;"></i>
                            </div>
                            <div style="display: flex; align-items: center; gap: 10px; color: var(--mox-muted-light); font-size: 12px; margin-top: 6px;">
                                <span>@sub.TweetCount tweets</span>
                                @if (sub.SubfolderCount > 0)
                                {
                                    <span style="display: inline-flex; align-items: center; gap: 3px;">
                                        <i class="bi bi-diagram-2" style="font-size: 10px;"></i> @sub.SubfolderCount sub
                                    </span>
                                }
                            </div>
                        </a>
                    }
                </div>
            }
            else
            {
                <div style="display: flex; align-items: center; gap: 8px; color: var(--mox-muted-light); font-size: 13.5px; padding: 4px 0;">
                    <i class="bi bi-folder2"></i> No subfolders here &mdash; add one from
                    <button class="manage-link" style="padding: 0;" @onclick="OpenManagePanel">Manage</button>.
                </div>
            }
        </div>

        <div class="tweet-list-header">
            <span style="font-weight: 600; color: var(--mox-ink);">
                @_model.TotalTweetCount Tweets
            </span>
            <div style="display: flex; align-items: center; gap: 10px;">
                <select class="mox-input" style="width: auto; padding: 6px 12px; font-size: 13px;" @bind="_sort" @bind:after="ReloadData">
                    <option value="votes">Most Voted</option>
                    <option value="newest">Newest</option>
                    <option value="oldest">Oldest</option>
                </select>
                <a href="/submit" class="mox-btn-primary" style="display: inline-flex; align-items: center; gap: 6px; font-size: 13px; padding: 6px 14px; text-decoration: none;">
                    <i class="bi bi-plus-lg"></i> Add Tweet
                </a>
            </div>
        </div>

        @if (_model.Tweets.Count > 0)
        {
            @foreach (var tweet in _model.Tweets)
            {
                <div style="margin-bottom: 16px;">
                    <TweetCard Tweet="@tweet"
                               ShowScreenshot="true"
                               ShowCapture="true"
                               ShowFolders="true"
                               OnVote="@(() => HandleVote(tweet.Id))" />
                </div>
            }

            <Pagination CurrentPage="@_model.CurrentPage"
                        TotalPages="@_model.TotalPages"
                        OnPageChange="@HandlePageChange" />
        }
        else
        {
            <EmptyState Icon="bi-folder2-open"
                        Title="No tweets in this folder yet"
                        Description="Archive a tweet here before it disappears from X.">
                <a href="/submit" class="mox-btn-primary" style="text-decoration: none;">
                    <i class="bi bi-plus-lg"></i> Add a Tweet
                </a>
            </EmptyState>
        }
    </div>

    @if (_showManagePanel)
    {
        <ManageFolderPanel FolderId="@FolderId"
                           OnClose="CloseManagePanel"
                           OnFolderUpdated="OnFolderUpdated" />
    }
}

@code {
    private FolderDetailPageModel? _model;
    private bool _loading = true;
    private string _sort = "votes";
    private int _page = 1;
    private bool _showManagePanel;
    private const int PageSize = 20;

    [Parameter]
    public Guid FolderId { get; set; }

    [Inject]
    private FolderDetailOrchestrator Orchestrator { get; set; } = default!;

    [Inject]
    private NavigationManager Navigation { get; set; } = default!;

    protected override async Task OnParametersSetAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        _model = await Orchestrator.GetAsync(FolderId, _sort, _page, PageSize);
        if (_model is not null)
        {
            _sort = _model.Sort;
        }

        _loading = false;
    }

    private async Task ReloadData()
    {
        _page = 1;
        await LoadData();
    }

    private async Task HandlePageChange(int page)
    {
        _page = page;
        await LoadData();
    }

    private async Task HandleVote(Guid tweetId)
    {
        await Task.CompletedTask;
    }

    private void OpenManagePanel()
    {
        _showManagePanel = true;
    }

    private void CloseManagePanel()
    {
        _showManagePanel = false;
    }

    private async Task OnFolderUpdated()
    {
        _showManagePanel = false;
        await LoadData();
    }
}
